{
  "name": "documentacao-sql",
  "displayName": "Documentação SQL Helper",
  "description": "",
  "version": "1.0.0",
  "publisher": "SurfSpot",
  "repository": {
    "type": "git",
    "url": "https://github.com/LaurentinoNicolas/documentacao-sql-helper"
  },
  "icon": "images/icon.png",
  "keywords": ["sql", "documentation", "database" , "procedure"],
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:documentacao-sql.configurar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "extensions": [
          ".sql"
        ]
      }
    ],
    "commands": [
      {
        "command": "documentacao-sql.addDoc",
        "title": "SQL Doc: Adicionar documentação"
      },
      {
        "command": "documentacao-sql.editDoc",
        "title": "SQL Doc: Editar documentação"
      },
      {
        "command": "documentacaoSql.configurar",
        "title": "Configurar conexão Documentação SQL"
      }
    ],
    "configuration": {
      "title": "Documentação SQL",
      "properties": {
        "documentacaoSql.db.server": {
          "type": "string",
          "default": ""
        },
        "documentacaoSql.db.database": {
          "type": "string",
          "default": ""
        },
        "documentacaoSql.db.user": {
          "type": "string",
          "default": ""
        },
        "documentacaoSql.usuario": {
          "type": "string",
          "default": ""
        }
      }
    },
    "dependencies": {
      "mssql": "^10.0.0"
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "mssql": "^12.5.0",
    "vscode-mssql": "^0.0.1-security"
  }
}
